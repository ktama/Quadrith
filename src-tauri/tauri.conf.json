{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Quadrith",
  "version": "0.1.0",
  "identifier": "com.quadrith.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Quadrith",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      },
      {
        "label": "quickadd",
        "title": "クイック追加",
        "width": 560,
        "height": 88,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
